  <note>
    <title>Recipe: Chocolate Cake</title>
    <created>20260203T180000Z</created>
    <updated>20260203T183000Z</updated>
    <tag>personal</tag>
    <tag>recipes</tag>
    <content><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd">
<en-note>
  <h2>Ingredients</h2>
  <ul>
    <li>200g dark chocolate</li>
    <li>175g butter</li>
    <li>3 eggs</li>
    <li>200g caster sugar</li>
    <li>100g plain flour</li>
  </ul>
  <h2>Method</h2>
  <ol>
    <li>Preheat oven to 180°C.</li>
    <li>Melt chocolate and butter together.</li>
    <li>Whisk eggs and sugar until pale, fold in chocolate mixture.</li>
    <li>Sift in flour, fold gently. Pour into tin and bake 25 minutes.</li>
  </ol>
  <p><i>Serves 8. Best served warm with cream.</i></p>
</en-note>]]></content>
  </note>

